# Neon Postgres — get this from your Neon project dashboard
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# JWT secrets — generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=replace-with-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

PORT=8080
NODE_ENV=development
